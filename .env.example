# Monomat-FE 환경변수 예시 파일
#
# 실제 배포 주소, 서버 IP, 도메인, 토큰 등 민감하거나 환경별로 달라지는 값은
# 이 파일에 직접 작성하지 말고 .env.development 또는 배포 플랫폼 환경변수에 설정합니다.
#
# Vite 환경변수는 반드시 VITE_ prefix를 사용해야 클라이언트 코드에서 접근할 수 있습니다.

# REST API 서버 base URL
#
# 로컬 개발에서 Vite proxy를 사용할 경우 비워두거나 설정하지 않아도 됩니다.
# 이 경우 FE는 같은 origin의 /api 경로로 요청합니다.
#
# 예시:
# VITE_API_BASE_URL=http://localhost:8080
# VITE_API_BASE_URL=https://api.example.com
VITE_API_BASE_URL=

# WebSocket SockJS endpoint
#
# src/constants/endpoints.ts에서 필수값으로 사용합니다.
# 로컬 개발에서는 Vite proxy를 사용할 수 있도록 /ws를 사용합니다.
#
# 예시:
# VITE_WS_URL=/ws
# VITE_WS_URL=https://api.example.com/ws
VITE_WS_URL=/ws

# MSW 사용 여부
#
# 실제 BE 연동 중에는 false를 권장합니다.
# mock API를 명시적으로 사용해야 할 때만 true로 설정합니다.
VITE_ENABLE_MSW=false